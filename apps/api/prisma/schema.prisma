generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkoutType {
  RUN_WALK
  EASY_RUN
  WALK
  BIKE
  STRENGTH
}

enum BreathingLevel {
  EASY
  MEDIUM
  HARD
  VERY_HARD
}

enum HeartRateZone {
  ZONE_1
  ZONE_2
  ZONE_3
  ZONE_4
  ZONE_5
}

enum PainType {
  NONE
  SHIN
  KNEE
  ACHILLES
  FOOT
  HIP
  BACK
  OTHER
}

model User {
  id             String            @id @default(cuid())
  email          String?           @unique
  googleId       String?           @unique
  googleLinkedAt DateTime?
  heightCm       Int               @default(185)
  goalSpeedKmh   Float             @default(12)
  easyHrMin      Int               @default(130)
  easyHrMax      Int               @default(150)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  authSessions   AuthSession[]
  recoveryCode   RecoveryCode?
  templates      WorkoutTemplate[]
  sessions       WorkoutSession[]
  strengthSessions StrengthWorkoutSession[]
  exerciseStates   UserExerciseState[]
  rules            UserRule[]
}

model AuthSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model RecoveryCode {
  id         String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
}

model WorkoutTemplate {
  id          String           @id @default(cuid())
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  level       Int
  type        WorkoutType
  warmupSec   Int
  runSec      Int
  walkSec     Int
  repeats     Int
  cooldownSec Int
  isDefault   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  sessions    WorkoutSession[]

  @@index([level])
  @@index([userId])
}

model WorkoutSession {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientSessionId   String?
  templateId        String?
  template          WorkoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  date              DateTime
  completed         Boolean          @default(true)
  totalDurationSec  Int
  totalRunSec       Int
  totalWalkSec      Int
  avgHr             Int?
  maxHr             Int?
  stopwatchPulseBpm Int?
  heartRateZone     HeartRateZone?
  distanceMeters    Int?
  avgPaceSecPerKm   Int?
  avgSpeedKmh       Float?
  cadenceSpm        Int?
  difficulty        Int
  breathing         BreathingLevel
  breathingNote     String?
  pain              PainType
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([userId, clientSessionId])
  @@index([userId, date])
  @@index([templateId])
}

model Exercise {
  id              String                     @id @default(cuid())
  slug            String                     @unique
  name            String
  category        String
  movementPattern String
  equipment       String
  difficulty      Int
  createdAt       DateTime                   @default(now())
  templateLinks   StrengthWorkoutExercise[]
  setLogs         StrengthSetLog[]
  feedback        StrengthExerciseFeedback[]
  userStates      UserExerciseState[]
  alternatives    ExerciseAlternative[]      @relation("ExerciseAlternatives")
  alternativeFor  ExerciseAlternative[]      @relation("ExerciseAlternativeTargets")

  @@index([category])
  @@index([movementPattern])
}

model StrengthWorkoutTemplate {
  id          String                    @id @default(cuid())
  code        String                    @unique
  name        String
  isDefault   Boolean                   @default(false)
  createdAt   DateTime                  @default(now())
  exercises   StrengthWorkoutExercise[]
  sessions    StrengthWorkoutSession[]
}

model StrengthWorkoutExercise {
  id          String                  @id @default(cuid())
  templateId  String
  template    StrengthWorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise                @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  sets        Int
  repsMin     Int
  repsMax     Int
  restSeconds Int
  sortOrder   Int

  @@unique([templateId, exerciseId])
  @@index([templateId, sortOrder])
  @@index([exerciseId])
}

model StrengthWorkoutSession {
  id              String                     @id @default(cuid())
  userId          String
  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId      String?
  template        StrengthWorkoutTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  date            DateTime
  completed       Boolean                    @default(true)
  durationMinutes Int?
  difficulty      Int
  notes           String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  setLogs         StrengthSetLog[]
  feedback        StrengthExerciseFeedback[]

  @@index([userId, date])
  @@index([templateId])
}

model StrengthSetLog {
  id          String                 @id @default(cuid())
  sessionId   String
  session     StrengthWorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise               @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  setNumber   Int
  reps        Int
  weightKg    Float?
  rpe         Int?
  completed   Boolean                @default(true)
  createdAt   DateTime               @default(now())

  @@unique([sessionId, exerciseId, setNumber])
  @@index([exerciseId])
}

model StrengthExerciseFeedback {
  id                  String                 @id @default(cuid())
  sessionId           String
  session             StrengthWorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId          String
  exercise            Exercise               @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  muscleDifficulty    Int?
  breathingDifficulty Int?
  pain                PainType
  comment             String?
  createdAt           DateTime               @default(now())

  @@unique([sessionId, exerciseId])
  @@index([exerciseId])
}

model UserExerciseState {
  id                     String   @id @default(cuid())
  userId                 String
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId             String
  exercise               Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  currentLevel           Int      @default(1)
  bestSetReps            Int?
  bestWeightKg           Float?
  bestVolume             Float?
  lastDifficulty         Int?
  averageDifficultyLast3 Float?
  lastPain               PainType?
  trend                  String?
  nextRecommendedSets    Int?
  nextRecommendedReps    String?
  updatedAt              DateTime @updatedAt

  @@unique([userId, exerciseId])
  @@index([exerciseId])
}

model UserRule {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  priority  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, type])
  @@index([userId, priority])
}

model ExerciseAlternative {
  id                    String   @id @default(cuid())
  exerciseId            String
  exercise              Exercise @relation("ExerciseAlternatives", fields: [exerciseId], references: [id], onDelete: Cascade)
  alternativeExerciseId String
  alternativeExercise   Exercise @relation("ExerciseAlternativeTargets", fields: [alternativeExerciseId], references: [id], onDelete: Cascade)
  reason                String
  difficultyDelta       Int      @default(0)

  @@unique([exerciseId, alternativeExerciseId, reason])
  @@index([alternativeExerciseId])
}
