[Unit]
Description=Run RunWalk Coach PostgreSQL restore drill
Requires=docker.service
After=docker.service run-walk-coach-backup.service
OnFailure=run-walk-coach-alert@%n.service

[Service]
Type=oneshot
EnvironmentFile=-/etc/run-walk-coach/ops.env
ExecStart=/usr/local/sbin/run-walk-coach-restore-drill
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
